{
  "name": "cartera-prestamos",
  "version": "1.2.4",
  "description": "Gestión de cartera de préstamos personales",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "build:win": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac dmg",
    "build:all": "electron-builder --win nsis --mac dmg"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.juanp.cartera",
    "productName": "Cartera de Prestamos",
    "icon": "build/icon.png",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "Instalador-Windows-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cartera de Prestamos",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeader": "build/icon.png",
      "deleteAppDataOnUninstall": false,
      "include": "build/uninstaller.nsh"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.finance",
      "icon": "build/icon.png",
      "artifactName": "Instalador-Mac-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "xJp-P",
      "repo": "cartera-prestamos",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": ".",
        "filter": [
          "!cartera.db",
          "!node_modules",
          "!dist",
          "!.git",
          "!.claude",
          "!.github"
        ]
      }
    ]
  }
}
